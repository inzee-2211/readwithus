    /* ------------------------ TIER --------------------------- */
    public function tierForm(int $id = 0)
    {
        $this->objPrivilege->canEditCategories();
        $db  = FatApp::getDb();
        $id  = $this->resolveId($id, 'id');
        $row = [];

        if ($id > 0) {
            $rs  = $db->query("SELECT id, name, examboard_id FROM course_tier WHERE id = ?", [$id]);
            $row = $db->fetch($rs) ?: [];
        }

        $boards = $db->fetchAll($db->query("SELECT id, name FROM course_examboards ORDER BY name ASC"));
        $opts   = array_column($boards, 'name', 'id');

        $frm = new Form('frmTier');
        $frm->addHiddenField('', 'id', $id);
        $frm->addSelectBox(Label::getLabel('LBL_EXAM_BOARD'), 'examboard_id', $opts)->requirements()->setRequired();
        $frm->addRequiredField(Label::getLabel('LBL_TIER'), 'name');
        $frm->addSubmitButton('', 'btn_submit', Label::getLabel('LBL_SAVE'));
        $frm->fill($row);
        $this->set('frm', $frm);
        $this->_template->render(false, false);
    }

    public function saveTier()
    {
        $this->objPrivilege->canEditCategories();
        $p    = FatApp::getPostedData();
        $id   = FatUtility::int($p['id'] ?? 0);
        $eb   = FatUtility::int($p['examboard_id'] ?? 0);
        $name = trim($p['name'] ?? '');
        if ($eb <= 0 || $name === '') FatUtility::dieJsonError('Exam Board & Tier required');

        $db = FatApp::getDb();
        $data = ['examboard_id' => $eb, 'name' => $name];
        $ok = ($id > 0)
            ? $db->updateFromArray('course_tier', $data, ['smt' => 'id = ?', 'vals' => [$id]])
            : $db->insertFromArray('course_tier', $data + ['created_at' => date('Y-m-d H:i:s')]);

        if (!$ok) FatUtility::dieJsonError($db->getError());
        FatUtility::dieJsonSuccess(Label::getLabel('LBL_SAVED_SUCCESSFULLY'));
    }

    public function deleteTier(int $id = 0)
    {
        $this->objPrivilege->canEditCategories();
        $db = FatApp::getDb();
        $id = $this->resolveId($id, 'id');
        if ($id <= 0) FatUtility::dieJsonError('Invalid Tier ID');

        if (!$db->deleteRecords('course_tier', ['id' => $id])) {
