        $rs    = $db->query("SELECT COUNT(*) AS c FROM course_tier WHERE examboard_id = ?", [$id]);
        $inUse = $db->fetch($rs);
        if ((int)($inUse['c'] ?? 0) > 0) {
            FatUtility::dieJsonError('Cannot delete: tiers exist for this exam board');
